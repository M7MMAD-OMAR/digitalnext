{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const p=require('path').join('.',q.url==='/'?'site.html':q.url);require('fs').readFile(p,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const m={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml'}[p.split('.').pop()]||'application/octet-stream';r.writeHead(200,{'Content-Type':m});r.end(d)}})}).listen(3001,()=>console.log('Server on 3001'))"],
      "port": 3001
    }
  ]
}